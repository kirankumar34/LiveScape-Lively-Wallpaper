{
  "manifest_version": 3,
  "name": "LiveScape – Live Wallpaper New Tab",
  "short_name": "LiveScape",
  "version": "1.0.0",
  "description": "Transform your Chrome new tab into a stunning live wallpaper. Permanent storage via IndexedDB, adaptive performance engine, and zero CPU waste.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "bookmarks"
  ],
  "host_permissions": [
    "https://api.openweathermap.org/*",
    "https://api.quotable.io/*",
    "https://fonts.googleapis.com/*",
    "https://fonts.gstatic.com/*"
  ],
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "settings/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "LiveScape Settings"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "components/*",
        "js/*",
        "css/*",
        "settings/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}